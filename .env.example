# Copy to .env and fill with real values.
# .env is gitignored — never commit secrets.

# PostgreSQL — get from Railway → Postgres service → Variables → DATABASE_PUBLIC_URL
DATABASE_URL=postgresql://user:password@host:port/dbname

# Frontend dev: full URL of your local FastAPI backend.
# Production (single-service deploy): leave empty so requests hit same origin.
VITE_API_URL=http://127.0.0.1:8001

# ─── Clerk auth (Sprint 2) ─────────────────────────────────────
# Get from Clerk Dashboard → API Keys.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Email of the user who should be admin on first login.
INITIAL_ADMIN_EMAIL=you@example.com
