# Copy to .env and fill with real values.
# .env is gitignored — never commit secrets.

# PostgreSQL — get from Railway → Postgres service → Variables → DATABASE_PUBLIC_URL
DATABASE_URL=postgresql://user:password@host:port/dbname

# Pytest — separate Postgres so tests don't TRUNCATE production data.
# Provision a second Railway Postgres (free tier) or run a local one
# (e.g. `docker run -p 5433:5432 -e POSTGRES_PASSWORD=test postgres:18`).
# pytest refuses to start if this is unset and DATABASE_URL points at
# a hosted DB — see /conftest.py for the safety check.
TEST_DATABASE_URL=postgresql://user:password@host:port/test_dbname

# Frontend dev: full URL of your local FastAPI backend.
# Production (single-service deploy): leave empty so requests hit same origin.
VITE_API_URL=http://127.0.0.1:8001

# ─── Clerk auth (Sprint 2) ─────────────────────────────────────
# Get from Clerk Dashboard → API Keys.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Email of the user who should be admin on first login.
INITIAL_ADMIN_EMAIL=you@example.com

# ─── Sentry (optional) ─────────────────────────────────────────
# Frontend DSN. Leave empty to disable Sentry; set on Railway to
# capture runtime errors during freeze-week testing and beyond.
# Get from Sentry → Project → Client Keys (DSN).
VITE_SENTRY_DSN=

# ─── Anonymous mode (LOCAL DEV ONLY) ───────────────────────────
# When both flags are 'true', requests without a Bearer token bind to
# a shared anonymous@local user (lazy-created on first hit, role='user').
# NEVER set on Railway — leaves /api/* open to anyone.
ALLOW_ANONYMOUS=false
VITE_ALLOW_ANONYMOUS=false
